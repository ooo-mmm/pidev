{
  "name": "pidev",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Vendored monorepo of pi-coding-agent extensions for ooo-mmm Nix consumption",
  "workspaces": ["packages/*", "packages/@*/*"],
  "scripts": {
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "overrides": {
    "tree-sitter-wasms": "npm:null@2.0.0",
    "@earendil-works/pi-coding-agent": "npm:null@2.0.0",
    "@earendil-works/pi-agent-core": "npm:null@2.0.0",
    "@earendil-works/pi-ai": "npm:null@2.0.0",
    "@earendil-works/pi-tui": "npm:null@2.0.0"
  }
}
