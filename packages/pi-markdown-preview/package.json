{
  "name": "pi-markdown-preview",
  "version": "0.10.0",
  "description": "Rendered markdown + LaTeX preview for pi, with terminal, browser, and PDF output",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.ts",
      "import": "./index.ts"
    }
  },
  "scripts": {
    "check:readme-commands": "node ./scripts/check-readme-commands.mjs",
    "check:regressions": "node ./test/regressions.mjs",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "keywords": [
    "pi-package"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omaclaren/pi-markdown-preview.git"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "image": "screenshots/dark-terminal.png"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "dependencies": {
    "puppeteer-core": "^24.22.3"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@earendil-works/pi-tui": "^0.78.0",
    "@types/node": "^24.3.0",
    "typebox": "^1.1.39",
    "typescript": "^5.7.3"
  }
}
