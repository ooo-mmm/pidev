      "expected": {
        "headless": { "verdict": "expected-fail", "blockedBy": "cloudflare" },
        "visible": { "verdict": "pass", "blockedBy": null }
      }
    },
    {
      "id": "perplexity-clipboard-empty",
      "name": "Perplexity — Clipboard Interceptor Empty",
